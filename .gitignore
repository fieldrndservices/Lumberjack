# --- LabVIEW ---
# Object cache and per-user settings (regenerable)
.cache/
*.aliases
*.lvlps

# --- Build outputs (regenerable, not committed) ---
/builds/
*.lvlibp        # Packed Project Library (output of Build PPL)
*.vip           # VI Package (output of Package)

# --- OS / editor cruft ---
.DS_Store
Thumbs.db
desktop.ini
*~
*.tmp

